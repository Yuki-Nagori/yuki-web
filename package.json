  "type": "module",
  "packageManager": "yarn@1.22.22",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.0.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.0.0",
    "vitepress": "^1.6.4",
    "vue": "^3.5.32",
    "vue-eslint-parser": "^10.0.0"
  },
  "resolutions": {
    "lodash-es": "4.18.1",
    "esbuild": "0.25.0"
  },
  "scripts": {
    "docs:dev": "yarn lint:fix && yarn format && vitepress dev docs",
