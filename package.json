    "docs:preview": "vitepress preview docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,vue,md,json,yml}\"",
    "format:check": "prettier --check \"**/*.{js,ts,vue,md,json,yml}\"",
    "type-check": "tsc --noEmit"
  }
